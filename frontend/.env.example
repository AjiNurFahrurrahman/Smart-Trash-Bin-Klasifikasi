# Salin file ini menjadi ".env"

# URL backend FastAPI (folder backend/ di proyek fullstack ini).
# Backend menangani Kelas, Akun, Poin, Leaderboard (MongoDB Atlas), DAN
# meneruskan gambar ke model AI (proxy ke Hugging Face Space -- lihat
# backend/.env.example untuk konfigurasi HF_SPACE_ID & HF_TOKEN di sana).
# Saat development lokal biasanya http://localhost:8000
# Saat produksi, ganti dengan URL backend yang sudah kamu deploy.
VITE_BACKEND_API_URL=http://localhost:8000
